# Secrets and credentials
.env

# mTLS certificates / private keys (devmgmt client identity, etc.) — never commit key material
certs/

# Editor/backup droppings
*.bak

# DigiSearch on-disk cache (API responses + token)
.digisearch_cache/

# Local settings override
config/settings.yaml

# PartPilot web app runtime data (user DB, uploaded BOMs, generated quote files)
data/

# Generated BOM reports and distributor cart CSVs
*-resolved.xlsx
*-cart.csv

# Python
__pycache__/
*.py[cod]
.venv/
.pytest_cache/
*.egg-info/
dist/
build/

# LibreOffice lock files
.~lock.*#
