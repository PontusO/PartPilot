# Digi-Key Product Information API v4 credentials (client-credentials / 2-legged OAuth2).
# Create a PRODUCTION App at https://developer.digikey.com (under your organization)
# subscribed to "Product Information V4", then paste its Client ID and Secret here.
DIGIKEY_CLIENT_ID=your-client-id
DIGIKEY_CLIENT_SECRET=your-client-secret

# Production returns real pricing/stock and is the default. The sandbox only returns
# mock data and needs separate sandbox-app credentials, so leave this false.
DIGIKEY_SANDBOX=false

# Locale for pricing and availability.
DIGIKEY_LOCALE_SITE=SE
DIGIKEY_LOCALE_LANGUAGE=en
DIGIKEY_LOCALE_CURRENCY=SEK

# Optional: Mouser Search API key (second-choice supplier behind Digi-Key).
# Request one at https://www.mouser.com/api-hub/. If unset, Mouser is simply not used.
MOUSER_API_KEY=

# Optional: devmgmt integration (PartPilot pushes its device catalog + per-device build
# records to devmgmt — see docs/partpilot-integration.md). Leave DEVMGMT_BASE_URL blank to
# disable; `digisearch devmgmt-push --dry-run` needs none of this.
DEVMGMT_BASE_URL=
# Auth mechanism: mtls (default, the chosen mechanism) | bearer | none (local stub/testing).
DEVMGMT_AUTH_MODE=mtls
# mTLS: PartPilot's client certificate + key, and (optionally) the CA bundle that verifies
# devmgmt's server cert. Paths on disk.
DEVMGMT_CLIENT_CERT=
DEVMGMT_CLIENT_KEY=
DEVMGMT_CA_CERT=
# Bearer alternative: the system token devmgmt issued for PartPilot.
DEVMGMT_BEARER_TOKEN=
